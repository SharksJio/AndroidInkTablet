<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include user drawings and preferences for cloud backup -->
        <include domain="file" path="drawings/"/>
        <include domain="sharedpref" path="ink_preferences.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Include user drawings and preferences for device transfer -->
        <include domain="file" path="drawings/"/>
        <include domain="sharedpref" path="ink_preferences.xml"/>
    </device-transfer>
</data-extraction-rules>